    "dev": "tsc && node dist/cli.js"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
