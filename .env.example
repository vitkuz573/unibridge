# unibridge — env overrides for top-level settings
# Backend configs go in unibridge.json (NOT in env vars)
#
# UNIBRIDGE_CONFIG=./unibridge.json   # explicit config path
# UNIBRIDGE_PORT=5200                 # listen port
# UNIBRIDGE_DEFAULT_BACKEND=opencode   # fallback backend name
# UNIBRIDGE_LOG=/tmp/unibridge.log    # log file
