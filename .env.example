# unibridge configuration
# Copy to .env and edit

# opencode backend
OPENCODE_BASE_URL=http://127.0.0.1:5100
OPENCODE_DEFAULT_MODEL=big-pickle

# Proxy
UNIBRIDGE_PORT=5200
UNIBRIDGE_DEFAULT_BACKEND=opencode
UNIBRIDGE_LOG=/tmp/unibridge.log

# Graphify Zen backend — add to ~/.graphify/providers.json:
# {"zen":{"base_url":"http://localhost:5200/v1","default_model":"big-pickle","env_key":"ZEN_API_KEY","pricing":{"input":0,"output":0},"temperature":0,"max_tokens":16384,"vision":true}}
ZEN_API_KEY=sk-zen
