# opencode-graphify-bridge configuration
# Copy to .env and edit

# opencode server URL
SDK_URL=http://127.0.0.1:5100

# Proxy listen port
PROXY_PORT=5200

# Default model (auto-detected from request if not set)
PROXY_MODEL=

# Provider namespace
PROXY_PROVIDER=opencode

# Graphify Zen backend — add to ~/.graphify/providers.json:
# {"zen":{"base_url":"http://localhost:5200/v1","default_model":"big-pickle","env_key":"ZEN_API_KEY","pricing":{"input":0,"output":0},"temperature":0,"max_tokens":16384,"vision":true}}
ZEN_API_KEY=sk-zen
